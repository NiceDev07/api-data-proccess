ENV=prod
HOST=0.0.0.0
PORT=3000
PREFIX_APP=/v2

# Directorio base donde se encuentran los archivos CSV/XLSX subidos
REPOSITORY_FILES_DIR=/ruta/a/los/archivos

# Directorio de salida para los archivos Parquet generados
OUTPUT_DIR=resultados

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_SAEM3=mysql+asyncmy://user:pass@host:3306/database
DB_PORTABILIDAD=mysql+asyncmy://user:pass@host:3306/database
DB_MASIVOS_SMS=mysql+asyncmy://user:pass@host:3306/database
DB_TELEFONOS_CAMPANAS=mysql+asyncmy://user:pass@host:3306/database
DB_EMAIL=mysql+asyncmy://user:pass@host:3306/database

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Límites de campaña ────────────────────────────────────────────────────────
# Máximo de registros por campaña para usuarios nivel > 1 (soporta hasta 1M+)
MAX_CAMPAIGN_RECORDS=700000

# ── Gunicorn (opcional, sobreescribe gunicorn.conf.py) ───────────────────────
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=300
# LOG_LEVEL=info
